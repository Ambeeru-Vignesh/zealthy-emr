# PostgreSQL database URL (required for production)
# Get a free database at https://neon.tech or use Vercel Postgres
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# For Neon (connection pooling): use pooled URL for DATABASE_URL
# For direct connections (e.g., migrations): use direct URL for DIRECT_URL
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# NextAuth - generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret"
NEXTAUTH_URL="https://your-app.vercel.app"

# Optional: change this token before deploying to secure the setup endpoint
SETUP_TOKEN="zealthy-setup-2026"
